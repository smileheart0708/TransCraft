# 统一使用 LF 行尾符
* text=auto eol=lf

# 明确指定文本文件
*.ts text eol=lf
*.js text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.yml text eol=lf
